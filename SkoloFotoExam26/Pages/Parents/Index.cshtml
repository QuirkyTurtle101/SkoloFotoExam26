@page
@using SkoloFotoExam26.Models
@model SkoloFotoExam26.Pages.Parents.IndexModel
@{
    ViewData["Titel"] = "Liste af forældre";
}

<h1>Forælder info</h1>

<div class="form-group mb-3">
    <a class="btn btn-primary" asp-page="CreateParent">Opret Forældreprofil</a>

    @* <a class="btn btn-primary" asp-page="/Students/Create">Tilmeld barn</a> *@

    @* <a class="btn btn-primary" asp-page="/Students/Index">Børn</a> *@
</div>

@*Maybe create a Filter here*@

@*Maybe create a Filter here*@

<table class="table">
    <thead>
        <tr>
            <form method"get">
            <th>
                    <button type="submit" class="btn btn-link" name="SortBy" value="ForældreID" >ID</button>
            </th>
            </form>
            <th>Fornavn</th>
            <th>Efternavn</th>
            <th>Email</th>
            <th>Telefonnummer</th>
            <th>By</th>
            <th>PostNummer</th>
            <th>Vejnavn</th>
        </tr>
    </thead>
    <tbody>
        @foreach (Parent item in @Model.Parents)
        {
            <tr>
                <td>@item.ID</td>
                <td>@item.FirstName</td>
                <td>@item.LastName</td>
                <td>@item.Email</td>
                <td>@item.PhoneNumber</td>
                <td>@item.City</td>
                <td>@item.ZipCode</td>
                <td>@item.Street</td>
                <td>
                    <div class="btn-group" role="group">
                        <a class="btn btn-primary" asp-page="/Students/Index">Børn</a>
                        <a class="btn btn-outline-info btn-sm" asp-page="IndexStudent" asp-route-ParentID="@item.ID">Børn</a>
                        <a asp-page="IndexStudent" asp-route-ParentID="@item.ID">Børne oversigt</a>
                        <a class="btn btn-primary" asp-page="/Students/CreateStudent">Tilmeld barn</a>
                        <a asp-page="CreateStudent" asp-route-ParentID="@item.ID">Tilføj barn</a>
                        <a asp-page="UpdateParent" asp-route-ParentID="@item.ID">Rediger forælder</a>
                        <a asp-page="DeleteParent" asp-route-ParentID="@item.ID">Slet forælder</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>