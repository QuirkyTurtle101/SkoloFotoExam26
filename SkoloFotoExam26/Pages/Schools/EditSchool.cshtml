@page
@using SkoloFotoExam26.Models
@model SkoloFotoExam26.Pages.Schools.EditSchoolModel
@{
    ViewData["Title"] = "Rediger skole";
}

<h1>Opdater skole</h1>
<form method="post">
    <input type="hidden" asp-for="@Model.SchoolToBeUpdated.SchoolID" /> 
    <div class="form-group">
        <label asp-for="@Model.SchoolToBeUpdated.Name" class="control-label"></label>
        <input asp-for="@Model.SchoolToBeUpdated.Name" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.SchoolToBeUpdated.Street" class="control-label"></label>
        <input asp-for="@Model.SchoolToBeUpdated.Street" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.SchoolToBeUpdated.ZipCode" class="control-label"></label>
        <input asp-for="@Model.SchoolToBeUpdated.ZipCode" class="form-control"/>
    </div>

    <div class="form-group">
        <label asp-for="@Model.SchoolToBeUpdated.City" class="control-label"></label>
        <input asp-for="@Model.SchoolToBeUpdated.City" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.SchoolToBeUpdated.SchoolType" class="control-label"></label>
        <select asp-for="@Model.SchoolToBeUpdated.SchoolType" asp-items="Html.GetEnumSelectList<SchoolType>()" class="form-control"></select>
    </div>
    <br />
    <div class="form-group">
        <input type="submit" value="Opdater skole" class="btn-primary" />
@*         <input type="submit" value="Slet skole" asp-page-handler="Delete" class="btn-danger" /> *@
        <input type="submit" value="Anuller" asp-page-handler="Cancel" class="btn-warning" />
    </div>

</form>