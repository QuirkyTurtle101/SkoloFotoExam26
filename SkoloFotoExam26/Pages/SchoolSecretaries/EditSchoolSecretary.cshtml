@page
@using SkoloFotoExam26.Models
@model SkoloFotoExam26.Pages.SchoolSecretaries.EditSchoolSecretaryModel
@{
    ViewData["Title"] = "Rediger skolesekretær";
}

<h1>Rediger skolesekretær</h1>
<form method="post">

    <input type="hidden" asp-for="@Model.SecretaryToBeUpdated.ID" />

    <div class="form-group">
        <label asp-for="@Model.SecretaryToBeUpdated.FirstName" class="control-label"></label>
        <input asp-for="@Model.SecretaryToBeUpdated.FirstName" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.SecretaryToBeUpdated.LastName" class="control-label"></label>
        <input asp-for="@Model.SecretaryToBeUpdated.LastName" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.SecretaryToBeUpdated.Initials" class="control-label"></label>
        <input asp-for="@Model.SecretaryToBeUpdated.Initials" class="form-control"/>
    </div>

    <div class="form-group">
        <label asp-for="@Model.SecretaryToBeUpdated.PhoneNumber" class="control-label"></label>
        <input asp-for="@Model.SecretaryToBeUpdated.PhoneNumber" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.SecretaryToBeUpdated.Email" class="control-label"></label>
        <input asp-for="@Model.SecretaryToBeUpdated.Email" readonly class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="ChosenSchool"> Choose a school </label>
        <select asp-for="ChosenSchool" class="form-select">
            <option value=""> Select school</option>
            @foreach (School s in @Model.Schools)
            {
                <option value="@s.SchoolID">
                    @s.Name
                </option>
            }
        </select>
    </div>



    <br />
    <div class="form-group">
        <input type="submit" value="Opdater sekretær" class="btn-primary" />
        <input type="submit" value="Slet sekretær" asp-page-handler="Delete" class="btn-danger" />
        <input type="submit" value="Cancel" asp-page-handler="Cancel" class="btn-warning" />
    </div>

</form>