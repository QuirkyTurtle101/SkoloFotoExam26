@page
@model SkoloFotoExam26.Pages.Administrators.EditAdminModel
@{
    ViewData["Title"] = "Rediger Administrator";
}

<h1>Rediger administrator</h1>
<form method="post">

    <input type="hidden" asp-for="@Model.AdminToBeUpdated.ID" />

    <div class="form-group">
        <label asp-for="@Model.AdminToBeUpdated.FirstName" class="control-label"></label>
        <input asp-for="@Model.AdminToBeUpdated.FirstName" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.AdminToBeUpdated.LastName" class="control-label"></label>
        <input asp-for="@Model.AdminToBeUpdated.LastName" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.AdminToBeUpdated.PhoneNumber" class="control-label"></label>
        <input asp-for="@Model.AdminToBeUpdated.PhoneNumber" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.AdminToBeUpdated.Email" class="control-label"></label>
        <input asp-for="@Model.AdminToBeUpdated.Email" readonly class="form-control" />
    </div>
    <br />
    <div class="form-group">
        <input type="submit" value="Opdater administrator" class="btn-primary" />
@*         <input type="submit" value="Slet sekretær" asp-page-handler="Delete" class="btn-danger" /> *@
        <input type="submit" value="Anuller" asp-page-handler="Cancel" class="btn-warning" />
    </div>

</form>