@page
@using SkoloFotoExam26.Models
@model SkoloFotoExam26.Pages.Photos.IndexModel
@{
    ViewData["Title"] = "Liste over Photos";
}
<h1>
    Liste over Fotos
</h1>
<p>
    <a asp-page="CreatePhoto"> lav et nyt foto </a>
</p>

<form method="get">
    <table class="table">
        <th> Foto type </th>
        <th> Pris </th>
        <th> Højde</th>
        <th> Bredde</th>
@*         <th> Bookingen</th>
 *@     <th></th>
        <tbody>
            @foreach (Photo p in @Model.PhotoList)
            {
                <tr>
                    <td> @p.PhotoType </td>
                    <td> @p.Price </td>
                    <td> @p.Height</td>
                    <td> @p.Width</td>
@*                     <td> @p.TheBooking.BookingID</td>
 *@
@*                     <td><a asp-page="DeletePhoto" asp-route-PhotoID="@p.PhotoID" class="btn btn-danger">Slet</a></td>
 *@                 <td><a asp-page="DisplayPhoto" asp-route-PhotoID="@p.PhotoID">Vis</a></td>
                </tr>
            }

        </tbody>
    </table>
</form>