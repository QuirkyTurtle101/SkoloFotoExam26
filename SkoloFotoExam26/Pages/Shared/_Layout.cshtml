<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SkoloFotoExam26</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SkoloFotoExam26.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">SkoloFotoExam26</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="PhotographingEvents/Index">PhotographingEvents</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Schools/Index">Skoler</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Bookings/Index">Bookings</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Teachers/Index">Teachers</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Parents/Index">Forældre</a>
                        </li>
                        

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/SchoolSecretaries/Index">Skolesekretærer</a>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>

        <div class="container py-2">
            @if (User.Identity.IsAuthenticated)
            {
                <a class="btn btn-sm btn-light border" asp-page="/Account/Profile">Min Profil</a>
            }
            else
            {
                <button type="button" class="btn btn-sm btn-light border" data-bs-toggle="modal" data-bs-target="#loginModal">
                    Log ind
                </button>
            }
        </div>

    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - SkoloFotoExam26 - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<div class="modal fade" id="loginModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content text-center p-4">
            <div class="d-flex justify-content-end">
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <h3 class="fw-bold">Login</h3>
            <hr style="border: 2px solid red; opacity: 1; width: 60%; margin: 10px auto 30px auto;">

            <form method="post" asp-page="/Account/Login">
                <div class="mb-3">
                    <input type="text" class="form-control" placeholder="User Number">
                </div>
                <div class="mb-3">
                    <input type="password" class="form-control" placeholder="Pin Code">
                </div>
                <button type="submit" class="btn btn-success w-100" style="background-color: #62c462; border: none;">Login</button>
            </form>

            <div class="mt-3 small">
                <a href="#" class="text-decoration-none">Glemt login</a>
                <br>
                <a href="#" class="text-muted text-decoration-none">Terms</a>
            </div>
        </div>
    </div>
</div>