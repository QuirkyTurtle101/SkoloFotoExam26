<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SkoloFotoExam26</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SkoloFotoExam26.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">SkoloFotoExam26</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="PhotographingEvents/Index">PhotographingEvents</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Schools/Index">Skoler</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/SchoolClasses/Index">SkoleKlasser</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Bookings/ChooseEvents">Bookings</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Teachers/Index">Teachers</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Parents/Index">Forældre</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/SchoolSecretaries/Index">Skolesekretærer</a>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>

        <div class="container d-flex justify-content-end">
            @if (User.Identity.IsAuthenticated)
            {
                <a class="btn btn-sm btn-login-tab" asp-page="/Account/Profile">Min Profil</a>
            }
            else
            {
                <button type="button" class="btn btn-sm btn-login-tab" data-bs-toggle="modal" data-bs-target="#loginModal">
                    Log ind
                </button>
            }
        </div>

    </header>
    <div class="container pt-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - SkoloFotoExam26 - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<div class="modal fade" id="loginModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content text-center p-4" style="border-radius: 15px; border: none; shadow: 0 5px 15px rgba(0,0,0,0.1);">
            <div class="d-flex justify-content-end">
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <h3 class="fw-bold" style="color: #4a4a4a;">Login</h3>
            <hr style="border: 2px solid #d1a678; opacity: 1; width: 60%; margin: 10px auto 30px auto;">

            <form method="post" asp-page="/Account/Login">
                <div class="mb-3 text-start">
                    <input type="text" class="form-control" placeholder="Brugernummer" style="border-radius: 8px;">
                </div>
                <div class="mb-3 text-start">
                    <input type="password" class="form-control" placeholder="Adgangskode" style="border-radius: 8px;">
                </div>
                <button type="submit" class="btn w-100" style="background-color: #d1a678; color: white; border: none; padding: 10px; border-radius: 8px; font-weight: bold;">Login</button>
            </form>

            <div class="mt-3 small">

                <a href="#" class="text-decoration-none" style="color: #d1a678;">Glemt login?</a>
                <br>
                <a href="#" class="text-muted text-decoration-none">Vilkår & betingelser</a>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-login-tab {
        border: 1px solid white;
        border-top: none;
        background-color: #d1a678;
        padding: 5px 15px;
        position: relative;
        top: -1px;
        border-radius: 0 0 4px 4px;
        z-index: 10;
    }

        .btn-login-tab:hover {
            background-color: #d1a678;
            border-color: #d1a678;
        }
</style>