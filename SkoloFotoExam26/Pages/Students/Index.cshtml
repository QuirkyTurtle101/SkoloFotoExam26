@page
@using SkoloFotoExam26.Models
@model SkoloFotoExam26.Pages.Students.IndexModel
@{
    ViewData["Titel"] = "Liste af børn";
}

<h1>Informationer</h1>

<p>
    <a asp-page="CreateStudent" class="btn btn-primary">Opret børneprofil</a>
</p>

<table class="table">
    <thead>
        <tr>
            <form method"get">
            <th>
                <button type="submit" class="btn btn-link" name="SortBy" value="BørneID">ID</button>
            </th>
            </form>
            <th>Fornavn</th>
            <th>Mellemnavn</th>
            <th>Efternavn</th>
            <th>ForældreID</th>
            <th>Skole navn</th>
            <th>Skoleklassen</th>
        </tr>
    </thead>
    <tbody>
        @foreach (Student item in @Model.Students)
        {
            <tr>
                <td>@item.FirstName</td>
                <td>@item.MiddleName</td>
                <td>@item.LastName</td>
                <td>@item.School.Name</td>
                <td>@item.SchoolClass.ClassName</td>
                <td>
                    <a asp-page="Details" asp-route-id="@item.StudentID" class="btn btn-info btn-sm">Vis</a>
                </td>
            </tr>
        }
    </tbody>
</table>